generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              Int           @id @default(autoincrement())
  eventName       String
  templateUrl     String
  certPrefix      String        @default("CERT/2026")
  isActive        Boolean       @default(true)
  expiryDate      DateTime?
  nameX           Float
  nameY           Float
  certX           Float
  certY           Float
  createdAt       DateTime      @default(now())
  slug            String        @unique
  nameColor       String        @default("#000000")
  certColor       String        @default("#000000")
  certFormat      String        @default("{nomor}/{prefix}/{tahun}")
  certStartNumber Int           @default(1)
  certPadding     Int           @default(3)
  certificates    Certificate[]
  whitelists      Whitelist[]
}

model Whitelist {
  id        Int      @id @default(autoincrement())
  name      String
  eventId   Int
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([name, eventId])
}

model Certificate {
  id      Int      @id @default(autoincrement())
  name    String
  certNo  String?
  eventId Int
  date    DateTime @default(now())
  event   Event    @relation(fields: [eventId], references: [id])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("admin")
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
